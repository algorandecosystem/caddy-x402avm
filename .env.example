# caddy-x402avm middleware runtime environment
# Caddy does not hold payer keys and does not own static payout recipients
# in AgentQuest production flow; recipients are provided dynamically by quote.

# Optional dynamic quote endpoint for split requirements (when enabled in Caddy x402 block)
# Example should point to your quote broker endpoint (world service / quote API).
# QUOTE_URL=http://localhost:8787/x402/quote
# QUOTE_BROKER_TOKEN=replace_with_PAYMENT_QUOTE_BROKER_TOKEN
# QUOTE_TIMEOUT_MS=3000

# Required: shared secret used to sign trusted settlement proof forwarded to world.
PROOF_SHARED_SECRET=replace-with-same-secret-as-world

# Optional: override which routes require settle-before-forward behavior.
# SETTLEMENT_GATE_PATH_REGEX=^/sessions/[^/]+/paid-action$
